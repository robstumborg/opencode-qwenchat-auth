{
  "name": "opencode-qwenchat-auth",
  "version": "0.1.0",
  "description": "opencode plugin for authenticating to qwen chat",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robstumborg/opencode-qwenchat-auth.git"
  },
  "homepage": "https://github.com/robstumborg/opencode-qwenchat-auth#readme",
  "bugs": {
    "url": "https://github.com/robstumborg/opencode-qwenchat-auth/issues"
  },
  "keywords": [
    "opencode",
    "qwen",
    "qwenchat",
    "oauth",
    "plugin",
    "auth"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc && node scripts/copy-fallback.mjs",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.6"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.6",
    "@opencode-ai/sdk": "^1.3.6",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@openauthjs/openauth": "^0.4.3"
  }
}
